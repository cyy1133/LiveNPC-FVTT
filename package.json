{
  "name": "fvtt-ai-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Standalone desktop runtime to connect FVTT <-> Discord <-> LLM for multi-NPC autonomy.",
  "author": "cyy1133",
  "homepage": "https://github.com/cyy1133/LiveNPC-FVTT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyy1133/LiveNPC-FVTT.git"
  },
  "bugs": {
    "url": "https://github.com/cyy1133/LiveNPC-FVTT/issues"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "set ELECTRON_DISABLE_SECURITY_WARNINGS=true && electron .",
    "diagnose": "node runtime/cli.js diagnose",
    "run-headless": "node runtime/cli.js run",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "local.fvtt.ai.npc.runtime",
    "productName": "FVTT AI NPC Runtime",
    "files": [
      "src/**",
      "runtime/**",
      "Spec.md",
      "README.md",
      "QUICKSTART_KR.md",
      "RELEASE_GUIDE_KR.md",
      "CHANGELOG.md",
      "docs/**",
      "config.example.json",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "win": {
      "target": "nsis"
    }
  }
}
